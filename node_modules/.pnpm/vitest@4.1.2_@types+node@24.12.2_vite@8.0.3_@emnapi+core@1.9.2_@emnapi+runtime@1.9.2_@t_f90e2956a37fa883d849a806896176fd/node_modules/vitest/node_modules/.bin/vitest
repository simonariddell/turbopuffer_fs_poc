#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/workspace/node_modules/.pnpm/vitest@4.1.2_@types+node@24.12.2_vite@8.0.3_@emnapi+core@1.9.2_@emnapi+runtime@1.9.2_@t_f90e2956a37fa883d849a806896176fd/node_modules/vitest/node_modules:/workspace/node_modules/.pnpm/vitest@4.1.2_@types+node@24.12.2_vite@8.0.3_@emnapi+core@1.9.2_@emnapi+runtime@1.9.2_@t_f90e2956a37fa883d849a806896176fd/node_modules:/workspace/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/workspace/node_modules/.pnpm/vitest@4.1.2_@types+node@24.12.2_vite@8.0.3_@emnapi+core@1.9.2_@emnapi+runtime@1.9.2_@t_f90e2956a37fa883d849a806896176fd/node_modules/vitest/node_modules:/workspace/node_modules/.pnpm/vitest@4.1.2_@types+node@24.12.2_vite@8.0.3_@emnapi+core@1.9.2_@emnapi+runtime@1.9.2_@t_f90e2956a37fa883d849a806896176fd/node_modules:/workspace/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../vitest.mjs" "$@"
else
  exec node  "$basedir/../../vitest.mjs" "$@"
fi
