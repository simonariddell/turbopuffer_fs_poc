{
  "name": "turbopuffer-fs-workspace",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "test:conformance": "pnpm --filter @workspace/turbopuffer-fs test:conformance && pnpm --filter @workspace/tpfs-shell test:conformance",
    "test:restart": "pnpm --filter @workspace/tpfs-shell test:restart",
    "test:agent": "pnpm --filter @workspace/tpfs-shell test:agent",
    "test:search-evals": "pnpm --filter @workspace/turbopuffer-fs test:search-evals"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@turbopuffer/turbopuffer": "^1.21.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
